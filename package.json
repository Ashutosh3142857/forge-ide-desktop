{
  "name": "forge-ide",
  "version": "1.0.0",
  "description": "Forge IDE — Cloud Development Environment. Better than Replit.",
  "main": "main.js",
  "homepage": "https://forge.run",
  "author": {
    "name": "Forge IDE",
    "email": "hello@forge.run"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win --x64 --config electron-builder.yml",
    "build:mac": "electron-builder --mac --config electron-builder.yml",
    "build:linux": "electron-builder --linux --config electron-builder.yml",
    "build:all": "electron-builder --win --mac --linux --config electron-builder.yml",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}
